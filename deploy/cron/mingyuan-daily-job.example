# Run the daily scan and paper-trading job at 15:00 China time, Monday to Friday.
# Make sure the server timezone is Asia/Shanghai:
#   sudo timedatectl set-timezone Asia/Shanghai
0 15 * * 1-5 APP_DIR=/opt/mingyuan/trading-system /bin/bash /opt/mingyuan/trading-system/deploy/scripts/run-daily-job.sh >> /opt/mingyuan/trading-system/output/logs/cron-daily-job.log 2>&1
